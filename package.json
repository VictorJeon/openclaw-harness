{
  "name": "openclaw-harness",
  "version": "0.2.3",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js --external:openclaw --external:openclaw/plugin-sdk --external:@anthropic-ai/claude-agent-sdk",
    "test": "node scripts/run-tests.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.92"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "esbuild": "^0.27.3",
    "nanoid": "^3.3.7"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "claude",
    "claude-code",
    "coding-agent",
    "ai",
    "anthropic",
    "agent",
    "code-generation",
    "automation",
    "cli",
    "background-process",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VictorJeon/openclaw-harness.git"
  },
  "homepage": "https://github.com/VictorJeon/openclaw-harness#readme",
  "bugs": {
    "url": "https://github.com/VictorJeon/openclaw-harness/issues"
  },
  "license": "MIT",
  "author": "Nova <nova@local>",
  "publishConfig": {
    "access": "public"
  },
  "description": "OpenClaw Harness: harness-first coding plugin with remote-realtime and local-cc worker backends."
}
